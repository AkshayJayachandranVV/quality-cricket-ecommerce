{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": [
      "ES2020"
    ],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "declaration": true,
    "types": ["jest", "node"],
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "src/server.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}